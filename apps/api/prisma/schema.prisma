generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BUY
  SELL
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  wallet       Wallet?
  transactions Transaction[]
}

model Coin {
  id        String   @id @default(uuid())
  name      String
  symbol    String   @unique
  image     String?
  price     Decimal  @default(0)
  change24h Decimal  @default(0)
  marketCap Decimal  @default(0)
  volume24h Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets       WalletAsset[]
  transactions Transaction[]
}

model Wallet {
  id         String        @id @default(uuid())
  userId     String        @unique
  balanceUsd Decimal       @default(10000)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets WalletAsset[]
}

model WalletAsset {
  id              String   @id @default(uuid())
  walletId        String
  coinId          String
  amount          Decimal  @default(0)
  averageBuyPrice Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([walletId, coinId])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  coinId    String?
  type      TransactionType
  amount    Decimal           @default(0)
  price     Decimal           @default(0)
  total     Decimal           @default(0)
  status    TransactionStatus @default(SUCCESS)
  createdAt DateTime          @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  coin Coin? @relation(fields: [coinId], references: [id], onDelete: SetNull)
}