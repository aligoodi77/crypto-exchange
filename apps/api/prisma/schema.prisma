generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BUY
  SELL
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(USER)
  tokenVersion Int    @default(0)

  emailVerifiedAt DateTime?

  wallet             Wallet?
  transactions       Transaction[]
  revokedTokens      RevokedToken[]
  verificationTokens VerificationToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coin {
  id        String  @id @default(uuid())
  name      String
  symbol    String  @unique
  image     String?
  price     Decimal @default(0)
  change24h Decimal @default(0)
  marketCap Decimal @default(0)
  volume24h Decimal @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walletAssets WalletAsset[]
  transactions Transaction[]

  @@index([isActive])
}

model Wallet {
  id         String   @id @default(uuid())
  userId     String   @unique
  balanceUsd Decimal  @default(10000)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets WalletAsset[]
}

model WalletAsset {
  id              String   @id @default(uuid())
  walletId        String
  coinId          String
  amount          Decimal  @default(0)
  averageBuyPrice Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([walletId, coinId])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  coinId    String?
  type      TransactionType
  amount    Decimal           @default(0)
  price     Decimal           @default(0)
  total     Decimal           @default(0)
  fee       Decimal           @default(0)
  status    TransactionStatus @default(SUCCESS)
  createdAt DateTime          @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  coin Coin? @relation(fields: [coinId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model RevokedToken {
  id        String   @id @default(uuid())
  tokenId   String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id        String                @id @default(uuid())
  tokenHash String                @unique
  type      VerificationTokenType
  userId    String
  expiresAt DateTime
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}
